# Backend (required for server)
DATABASE_URL=mysql://user:password@localhost:3306/clientcheck
PORT=3000
SESSION_SECRET=replace-me
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# Stripe (server: sk_live_*; app: pk_live_* only in EXPO_PUBLIC_*)
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me

# Optional: customer subscription price IDs (server)
# STRIPE_PRICE_ID_MONTHLY=price_xxx
# STRIPE_PRICE_ID_YEARLY=price_xxx

# SendGrid
SENDGRID_API_KEY=replace-me
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_PHONE_NUMBER=+1234567890

# AWS S3 (photo uploads). Backend reads AWS_S3_BUCKET_NAME; S3_BUCKET is fallback.
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=clientcheck-prod
S3_BUCKET=clientcheck-prod

# Optional (server)
APP_BASE_URL=https://your-api.example.com
ADMIN_EMAIL=support@yourdomain.com
NODE_ENV=development
SENTRY_DSN=
REDIS_URL=
BACKUP_LOCATION=

# App / EAS (set in EAS secrets or .env; only EXPO_PUBLIC_* are safe in client bundle)
EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_OAUTH_PORTAL_URL=
EXPO_PUBLIC_OAUTH_SERVER_URL=
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_OWNER_OPEN_ID=
EXPO_PUBLIC_OWNER_NAME=
