# ============================================================
# BACKEND (Railway / server environment variables)
# ============================================================

# Must match the database your API server uses. After changing schema in code, run: npm run db:migrate
DATABASE_URL=mysql://user:password@host:port/clientcheck
PORT=3000
SESSION_SECRET=replace-me
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# Stripe (backend)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe product & price IDs (defaults baked into billing-config.ts)
STRIPE_PRICE_ID_MONTHLY=price_1TDW8KA5TLBlpCILQe0qFO4n
# Optional: dedicated Checkout price for customer identity verification (defaults to STRIPE_PRICE_ID_MONTHLY)
STRIPE_IDENTITY_PRICE_ID=
STRIPE_PRICE_ID_YEARLY=price_1TDW8DA5TLBlpCILStwOTXZf
STRIPE_PRODUCT_ID_CONTRACTOR=prod_UBtvKn3aCsXHU3
STRIPE_PRODUCT_ID_CUSTOMER=prod_UBtvxiCvktU4oo

# Backend base URL (used for webhooks, CORS, API). Often same host as the deployed web app.
APP_BASE_URL=https://clientcheck-production.up.railway.app

# OAuth (server) — token exchange with your auth provider. Must match the app configured in the portal.
OAUTH_SERVER_URL=
# App id the server uses when exchanging codes (should match EXPO_PUBLIC_APP_ID on clients).
VITE_APP_ID=
OWNER_OPEN_ID=

# After /api/oauth/callback sets the session cookie, browser redirect target.
# Production: set to your real web app origin (often same as APP_BASE_URL). Do not leave unset on production if APP_BASE_URL is empty.
# Local dev: defaults to http://localhost:8081 when NODE_ENV is not production.
OAUTH_WEB_REDIRECT_URL=
# Optional alias if the marketing/web app origin differs from APP_BASE_URL
FRONTEND_URL=

# SendGrid
SENDGRID_API_KEY=replace-me
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_PHONE_NUMBER=+1234567890

# AWS S3 (photo uploads)
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=clientcheck-prod
S3_BUCKET=clientcheck-prod

# Algolia (customer search) — ALGOLIA_ADMIN_API_KEY is the server admin/write key (some teams call it ALGOLIA_ADMIN_KEY).
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=
ALGOLIA_CUSTOMERS_INDEX_NAME=customers

# Optional (server)
ADMIN_EMAIL=support@clientcheck.app
NODE_ENV=production
SENTRY_DSN=
# Expo Sentry plugin + source maps:
# - local dev: export SENTRY_AUTH_TOKEN in your shell instead of storing it in git
# - EAS/CI: add SENTRY_AUTH_TOKEN as a build secret
# Token: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
REDIS_URL=
BACKUP_LOCATION=

# PostHog — server (beta funnel admin tab): HogQL via personal API key (Query read) + numeric project ID from project settings.
# Client event capture uses EXPO_PUBLIC_POSTHOG_* in the FRONTEND section below (separate from these).
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
# Optional. Default https://us.posthog.com — use https://eu.posthog.com for EU cloud.
POSTHOG_QUERY_HOST=
# Optional. Server-side funnel events (referral_verified, reward_earned). Defaults to EXPO_PUBLIC_POSTHOG_* if unset — set on the API host so Node can read them.
POSTHOG_CAPTURE_API_KEY=
POSTHOG_CAPTURE_HOST=

# ============================================================
# STAGING vs PRODUCTION (closed beta)
# ============================================================
# Use separate Railway (or other) services or env groups:
#   Staging: EXPO_PUBLIC_API_BASE_URL + APP_BASE_URL → staging API; EAS "preview" profile; Stripe test keys.
#   Production: same vars → production API; EAS "production"; Stripe live keys.
# Never point a production mobile build at a localhost API.

# ============================================================
# FRONTEND (Expo .env / EAS secrets — only EXPO_PUBLIC_* are
# bundled into the client app)
# ============================================================

# Required: your deployed API origin (no trailing slash). Local dev may use http://localhost:3000.
EXPO_PUBLIC_API_BASE_URL=https://clientcheck-production.up.railway.app
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Client crash reporting (public DSN; safe to bundle). Native source maps: set SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN (local .env and/or EAS project secrets for preview/production builds).
EXPO_PUBLIC_SENTRY_DSN=
# Ingestion key for the app (capture). Not used for admin funnel queries — those use POSTHOG_PERSONAL_API_KEY on the server.
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# true = mock client data only; false = real API (see EXPO_PUBLIC_API_BASE_URL)
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_OAUTH_PORTAL_URL=
EXPO_PUBLIC_OAUTH_SERVER_URL=
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_OWNER_OPEN_ID=
EXPO_PUBLIC_OWNER_NAME=

# Algolia (client: search-only key + same app id & index name as server).
# EXPO_PUBLIC_ALGOLIA_SEARCH_KEY is accepted as an alias for EXPO_PUBLIC_ALGOLIA_SEARCH_API_KEY.
EXPO_PUBLIC_ALGOLIA_APP_ID=
EXPO_PUBLIC_ALGOLIA_SEARCH_API_KEY=
EXPO_PUBLIC_ALGOLIA_SEARCH_KEY=
EXPO_PUBLIC_ALGOLIA_CUSTOMERS_INDEX_NAME=customers

# Public web origin for share links (`/c/:customerId?ref=:userId`). Falls back to `window.location.origin` on web.
EXPO_PUBLIC_APP_URL=https://clientcheck.com
# Optional store URLs for shared-link landing on native (fallback: web sign-up).
EXPO_PUBLIC_IOS_APP_STORE_URL=
EXPO_PUBLIC_ANDROID_PLAY_URL=

# ============================================================
# STRIPE WEBHOOK ENDPOINT (configure in Stripe Dashboard)
# ============================================================
# URL: https://clientcheck-production.up.railway.app/api/webhooks/stripe
# Events: payment_intent.succeeded, payment_intent.payment_failed,
#          charge.refunded, customer.subscription.created,
#          customer.subscription.updated, customer.subscription.deleted,
#          invoice.payment_succeeded, invoice.payment_failed
